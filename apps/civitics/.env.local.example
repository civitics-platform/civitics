# Copy this file to .env.local and fill in values.
# In a monorepo setup, values can also live at the repo root in /.env.local
# — next.config.mjs loads that file automatically.

# Supabase (browser-safe — new publishable key, not legacy anon key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Supabase (server-only — new secret key, not legacy service_role key)
SUPABASE_SECRET_KEY=sb_secret_xxx

# Mapbox (browser-safe — scope to your domain in Mapbox dashboard)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# Claude API (server-only)
# Named CIVITICS_ prefix so Claude Code CLI uses its own Pro subscription instead
CIVITICS_ANTHROPIC_API_KEY=sk-ant-your-key

# Cloudflare R2 (server-only)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=civitics-documents

# Congress.gov API (server-only)
CONGRESS_API_KEY=your-congress-api-key

# Privy (Phase 4 — leave blank until then)
NEXT_PUBLIC_PRIVY_APP_ID=
