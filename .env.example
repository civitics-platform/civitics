# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Anthropic
# Use CIVITICS_ANTHROPIC_API_KEY (not ANTHROPIC_API_KEY) so Claude Code CLI
# uses its own Pro subscription instead of this key.
CIVITICS_ANTHROPIC_API_KEY=
ANTHROPIC_ADMIN_API_KEY=
ANTHROPIC_ORG_ID=

# Mapbox (when needed)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Storage (Supabase now, R2 later)
STORAGE_PROVIDER=r2

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_DOCUMENTS=civitics-documents
CLOUDFLARE_R2_BUCKET_CACHE=civitics-cache
CLOUDFLARE_R2_PUBLIC_URL_DOCUMENTS=

# Vercel (for deployment status in dashboard)
VERCEL_TOKEN=
VERCEL_PROJECT_ID=
VERCEL_AI_API_TOKEN=

# Data Pipelines
CONGRESS_API_KEY=
COURTLISTENER_API_KEY=
OPENSTATES_API_KEY=
FEC_API_KEY=
REGULATIONS_API_KEY=


### NOT ACTIVE YET - for future use
# Resend (when needed)
RESEND_API_KEY=

# Sentry (when needed)
NEXT_PUBLIC_SENTRY_DSN=




CRON_SECRET=

# Admin dashboard access — must match the Supabase auth email for the admin account
# Controls access to manual pipeline triggers and budget controls on the dashboard
ADMIN_EMAIL=

# Feature flags — set to 'false' to disable without a code deploy
# CONNECTIONS_PIPELINE_ENABLED=false
# AI_SUMMARIES_ENABLED=false
# CHORD_DATA_ENABLED=false
# CRON_DISABLED=true
